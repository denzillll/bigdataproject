# Google Cloud / BigQuery credentials
# Path to service account JSON keyfile (download from GCP Console → IAM → Service Accounts → Keys)
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/covid-bigquery-service-account.json

# BigQuery project ID (defaults to covid-bigquery-494113)
BQ_PROJECT_ID=covid-bigquery-494113

# Postgres (Assignment 1, optional)
PGHOST=localhost
PGPORT=5432
PGDATABASE=covid_db
PGUSER=postgres
PGPASSWORD=your-password-here
